# ---------------------------------------------------------------------------
# Life OS environment variables. Copy to `.env.local` and fill in real values.
#   cp .env.example .env.local
# ---------------------------------------------------------------------------

# MongoDB Atlas connection URI (required)
# Example: mongodb+srv://user:pass@cluster0.abcde.mongodb.net/lifeos?retryWrites=true&w=majority
MONGODB_URI=

# Authentication (required) -------------------------------------------------
# The single password used to sign in to the dashboard.
APP_PASSWORD=
# Secret used to sign session cookies. Must be at least 16 characters.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Cloudinary credentials (required for document uploads) --------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Public Cloudinary values (exposed to the browser) -------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
